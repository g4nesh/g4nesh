<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ganeshtalluri.github-profile-token-counter</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>node</string>
    <string>/Users/ganeshtalluri/Documents/g4nesh/scripts/update-codex-token-counter.mjs</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/ganeshtalluri/Documents/g4nesh</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>TZ</key>
    <string>America/Phoenix</string>
    <key>TOKEN_COUNTER_START_DATE</key>
